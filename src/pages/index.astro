---
import '../styles/global.css';
import { profile, publications, research, talks, teaching } from '../data/site';

const sections = ['research', 'publications', 'teaching', 'talks'];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={`${profile.name} researches law, artificial intelligence, legal information retrieval, and computational legal studies.`} />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#f5f2eb" />
    <title>{profile.name} | Computational Law</title>
    <script is:inline>
      const savedTheme = localStorage.getItem('theme');
      document.documentElement.dataset.theme = savedTheme || 'light';
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <a class="wordmark" href="#top" aria-label={`${profile.name}, home`}>
        <span>CK</span>
        <strong>{profile.name}</strong>
      </a>
      <nav aria-label="Primary navigation">
        {sections.map((section) => <a href={`#${section}`}>{section}</a>)}
      </nav>
      <button class="theme-toggle" type="button" aria-label="Toggle colour theme">◐</button>
    </header>

    <main id="main">
      <section class="hero" id="top">
        <div class="hero-copy">
          <p class="eyebrow">Computational law · Legal informatics · Law and AI</p>
          <h1>{profile.name}</h1>
          <p class="role">{profile.title}</p>
          <p class="affiliation">{profile.affiliation}</p>
          <p class="bio">{profile.bio}</p>
          <div class="hero-actions">
            <a class="button primary" href="#publications">View publications</a>
            <a class="button secondary" href={`mailto:${profile.email}`}>Contact</a>
          </div>
          <ul class="profile-links" aria-label="Academic profiles">
            {profile.links.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
          </ul>
        </div>

        <div class="portrait-column">
          <img
            class="portrait-image"
            src="/profile_image.jpg"
            alt={`Portrait of ${profile.name}`}
            loading="eager"
            decoding="async"
          />
        </div>
      </section>

      <section class="section" id="research">
        <div class="section-heading">
          <p class="eyebrow">01</p>
          <h2>Research</h2>
          <p>My work examines how computational methods can support legal inquiry without losing sight of institutional context, accountability, and human judgment.</p>
        </div>
        <div class="card-grid">
          {research.map((item) => (
            <article class="research-card">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="publications">
        <div class="section-heading split">
          <div>
            <p class="eyebrow">02</p>
            <h2>Publications</h2>
          </div>
          <p>Articles, conference papers, working papers, datasets, and software. Replace the sample records in <code>src/data/site.ts</code>.</p>
        </div>
        <div class="publication-list">
          {publications.map((publication) => (
            <article class="publication">
              <div class="publication-meta">
                <span>{publication.year}</span>
                <span>{publication.type}</span>
              </div>
              <div>
                <h3>{publication.title}</h3>
                <p class="authors">{publication.authors}</p>
                <p>{publication.venue}</p>
                <div class="item-links">
                  {publication.links.map((link) => <a href={link.href}>{link.label} ↗</a>)}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="teaching">
        <div class="section-heading">
          <p class="eyebrow">03</p>
          <h2>Teaching</h2>
        </div>
        <div class="timeline">
          {teaching.map((item) => (
            <article class="timeline-item">
              <p class="timeline-date">{item.term}</p>
              <div>
                <h3>{item.title}</h3>
                <p class="item-subtitle">{item.institution} · {item.role}</p>
                <p>{item.description}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section" id="talks">
        <div class="section-heading">
          <p class="eyebrow">04</p>
          <h2>Talks</h2>
        </div>
        <div class="timeline">
          {talks.map((talk) => (
            <article class="timeline-item">
              <p class="timeline-date">{talk.date}</p>
              <div>
                <h3>{talk.title}</h3>
                <p class="item-subtitle">{talk.event} · {talk.location}</p>
                <div class="item-links">
                  {talk.links.map((link) => <a href={link.href}>{link.label} ↗</a>)}
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    </main>

    <footer>
      <p>© {new Date().getFullYear()} {profile.name}</p>
      <p>Built for clarity, accessibility, and long-term maintainability.</p>
    </footer>

    <script>
      const button = document.querySelector('.theme-toggle');
      button?.addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>
  </body>
</html>
